# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Square POS
VITE_SQUARE_APP_ID=your_square_app_id
VITE_SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_APP_SECRET=your_square_app_secret

# Encryption (shared between Square + Xero token storage)
AES_ENCRYPTION_KEY=your_32_byte_hex_encryption_key
HMAC_SECRET=your_hmac_secret_for_oauth_state

# Claude AI (Vercel serverless functions only — invoice parsing)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Xero (optional — accounting integration)
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=https://your-domain.vercel.app/api/xero/callback
